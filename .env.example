# Application
PORT=3001
NODE_ENV=development

# Database (Neon PostgreSQL)
# Use pooled connection string for runtime
DATABASE_URL=postgresql://USER:PASSWORD@HOST/livoclouds?sslmode=require&pgbouncer=true&connect_timeout=15
# Use direct connection string for Prisma migrations
DIRECT_URL=postgresql://USER:PASSWORD@HOST/livoclouds?sslmode=require

# JWT
JWT_SECRET=replace-with-a-secure-random-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-secure-random-secret-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:3000,https://app.livoclouds.com
