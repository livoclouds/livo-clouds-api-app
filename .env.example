# ─── Application ─────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── Observability — Sentry (error monitoring) ───────────────────────────────
# Leave SENTRY_DSN empty to keep Sentry fully DISABLED (the default — the SDK
# initialises as a no-op and sends nothing). Provision a DSN from sentry.io
# (create a "Node.js / NestJS" project) to start capturing errors. Every event is
# tagged with condominiumId + the acting user for tenant-scoped triage.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development           # e.g. development | staging | production
SENTRY_TRACES_SAMPLE_RATE=0              # 0–1 performance-trace sample rate (0 = off)

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Neon provides two connection strings per branch:
#   - Pooled (DATABASE_URL): used by the API at runtime (PgBouncer)
#   - Direct (DIRECT_URL):   used by Prisma for migrations and schema introspection
#
# DEVELOPMENT: copy connection strings from Neon Dashboard → Branch: Development
# PRODUCTION:  set these variables directly on your deployment platform (Vercel, Railway, etc.)
#              Never commit production credentials to the repository.
#
DATABASE_URL=postgresql://USER:PASSWORD@POOLER_HOST/DB_NAME?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@DIRECT_HOST/DB_NAME?sslmode=require
#
# Prisma observability (optional — OFF by default). When enabled, only queries
# slower than PRISMA_SLOW_QUERY_MS are logged, and only SQL text + duration are
# emitted (never bound parameter values). Engine warnings/errors are always
# surfaced regardless of this flag.
PRISMA_QUERY_LOGGING_ENABLED=false
PRISMA_SLOW_QUERY_MS=500

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=replace-with-a-secure-random-secret-minimum-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-secure-random-secret-minimum-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:3000,https://app.livoclouds.com

# ─── File Storage (Cloudflare R2) ─────────────────────────────────────────────
# Optional — the import pipeline works without these (files are parsed and discarded
# after hash computation). Configure to enable original file retention for audit
# purposes, logo uploads, and future document storage.
#
# Setup: Cloudflare Dashboard → R2 → Create bucket → Manage R2 API Tokens
# Endpoint format: https://{R2_ACCOUNT_ID}.r2.cloudflarestorage.com
#
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=livoclouds-files
R2_PUBLIC_URL=                          # optional: custom domain for public assets only

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Required for the forgot-password / reset-password flow (Phase 6).
# Obtain an API key from: https://resend.com/api-keys
# EMAIL_FROM must use a verified Resend domain: https://resend.com/domains
# APP_URL is the base URL of the web app, used to build reset links in emails.
#
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=LivoClouds <noreply@livoclouds.com>
APP_URL=http://localhost:3000

# ─── Communications — WhatsApp (Meta Cloud API) ──────────────────────────────
# Required once a condominium connects a WhatsApp Business number.
# WHATSAPP_ENCRYPTION_KEY: 32-byte hex key for AES-256-GCM credential encryption.
#   Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WHATSAPP_META_APP_SECRET=your-meta-app-secret
WHATSAPP_ENCRYPTION_KEY=replace-with-64-hex-chars
WHATSAPP_GRAPH_API_VERSION=v20.0
WEB_APP_URL=http://localhost:3000
WHATSAPP_ESCALATION_TEMPLATE_NAME=escalation_notification
WHATSAPP_ESCALATION_TEMPLATE_LANGUAGE=es_MX
WHATSAPP_MEDIA_PROXY_RATE_LIMIT=200

# ─── Internal cron (Vercel Cron Jobs) ────────────────────────────────────────
# Shared secret protecting /internal/cron/* endpoints (re-notify + retention sweep).
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace-with-a-secure-random-secret

# ─── Communications — Web Push (Phase 5) ─────────────────────────────────────
# VAPID keypair for Web Push admin notifications. Generate ONCE with:
#   npx web-push generate-vapid-keys
# The same public key must also be set in the web app as
# NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY. Leave blank to disable Push dispatch.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:contact@livoclouds.com
