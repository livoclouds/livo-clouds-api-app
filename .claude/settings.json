{
  "worktree": {
    "bgIsolation": "worktree"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/skills/clean-architecture-guardian/hooks/detect-architecture-intent.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/skills/api-endpoint-guardian/hooks/track-endpoints.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/skills/clean-architecture-guardian/hooks/track-architecture.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/skills/api-endpoint-guardian/hooks/check-endpoints.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/skills/clean-architecture-guardian/hooks/check-architecture.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Bash(git *)",
      "Bash(gh pr *)",
      "Bash(gh api *)",
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm test *)",
      "Bash(npm run lint)",
      "Bash(npm run build)",
      "Bash(npm run test:e2e *)",
      "Bash(npx tsc *)",
      "Bash(npx prisma *)",
      "Bash(npx --prefix * tsc *)",
      "Bash(lsof -i *)",
      "Bash(pkill -f *)",
      "Bash(until gh *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:docs.github.com)",
      "WebFetch(domain:www.prisma.io)",
      "WebFetch(domain:nestjs.com)",
      "Read(~/Code/github/livoclouds/livo-clouds-web-app/**)",
      "Read(~/code/github/livoclouds/livo-clouds-web-app/**)"
    ],
    "deny": [
      "Bash(PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=*)",
      "Bash(PRISMA_USER_CONSENT_FOR_DANGEROUS_AI_ACTION=* *)"
    ]
  }
}
