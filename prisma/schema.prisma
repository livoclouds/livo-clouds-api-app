  serialNumber    String?
  quantity        Int                @default(1)
  condition       InventoryCondition @default(GOOD)
  purchaseDate    DateTime?          @db.Date
  approximateCost Decimal?           @db.Decimal(12, 2)
  supplier        String?
  hasInvoice      Boolean            @default(false)
  invoiceNumber   String?
  notes           String?
  deletedAt       DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  // Audit-trail actor ids (the JWT `sub` of the acting user). API-owned: set
  // from the session on create/update, never accepted from the request body.
  // Nullable so rows created before this column existed remain valid.
  createdBy       String?
  updatedBy       String?

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  commonArea  CommonArea  @relation(fields: [commonAreaId], references: [id])

  @@index([condominiumId])
  @@index([commonAreaId])
  @@index([condition])
  @@index([deletedAt])
  @@map("inventory_items")
