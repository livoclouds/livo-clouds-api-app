/// A request for quotes on a piece of work (painting, gate repair, etc.). Each
/// request gathers one or more provider Quotations; the chosen one is tracked by
/// `selectedQuotationId` (a plain id, validated in the service against the
/// request's own quotations — no FK cycle). Soft-deleted via `deletedAt`.
model QuotationRequest {
  id            String            @id @default(uuid())
  condominiumId String
  title         String
  description   String            @default("")
  category      QuotationCategory
  status        QuotationStatus   @default(received)
  targetStartDate DateTime?       @db.Date
  targetEndDate   DateTime?       @db.Date
  // Id of the winning Quotation (one of this request's `quotations`), or null.
  selectedQuotationId String?
  beforePhotos  String[]          @default([])
  afterPhotos   String[]          @default([])
  comments      String            @default("")
  // JWT `sub` of the actor. API-owned, never from the request body.
  createdBy     String?
  updatedBy     String?
  deletedAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

