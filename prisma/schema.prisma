model WhatsAppFaq {
  id              String    @id @default(uuid())
  condominiumId   String
  category        String?
  triggers        String[]
  answer          String
  sortOrder       Int       @default(0)
  isActive        Boolean   @default(true)
  usageCount      Int       @default(0)
  lastUsedAt      DateTime?
  createdByUserId String
  updatedByUserId String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  createdBy   User        @relation("FaqCreatedBy", fields: [createdByUserId], references: [id])
  updatedBy   User        @relation("FaqUpdatedBy", fields: [updatedByUserId], references: [id])

  @@index([condominiumId, isActive, sortOrder])
  @@index([condominiumId, category])
  @@map("whatsapp_faqs")
}

model WhatsAppConversation {
  id                    String                     @id @default(uuid())
  condominiumId         String
  residentId            String?
  unregisteredContactId String?
  phoneNumber           String
  contactName           String?
  status                WhatsAppConversationStatus @default(BOT_ACTIVE)
  isOutOfHoursQueue     Boolean                    @default(false)
  lastInboundAt         DateTime?
  lastOutboundAt        DateTime?
  escalatedAt           DateTime?
  takenOverByUserId     String?
  takenOverAt           DateTime?
  resolvedAt            DateTime?
  resolvedByUserId      String?
  consecutiveFaqMisses  Int                        @default(0)
  unreadCountForAdmin   Int                        @default(0)
  isSystemChannel       Boolean                    @default(false)
  firstNotifiedAt       DateTime?
  reNotifiedAt          DateTime?
  beRightWithYouSentAt  DateTime?
  createdAt             DateTime                   @default(now())
  updatedAt             DateTime                   @updatedAt

  condominium         Condominium                  @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  resident            Resident?                    @relation(fields: [residentId], references: [id])
  takenOverBy         User?                        @relation("ConversationTakenOverBy", fields: [takenOverByUserId], references: [id])
  resolvedBy          User?                        @relation("ConversationResolvedBy", fields: [resolvedByUserId], references: [id])
  unregisteredContact WhatsAppUnregisteredContact? @relation(fields: [unregisteredContactId], references: [id])
  messages            WhatsAppMessage[]

  @@unique([condominiumId, phoneNumber, status])
  @@index([condominiumId, status, lastInboundAt])
  @@index([condominiumId, residentId])
  @@index([condominiumId, unregisteredContactId])
  @@index([status, firstNotifiedAt, reNotifiedAt])
  @@map("whatsapp_conversations")
}

model WhatsAppMessage {
  id             String                   @id @default(uuid())
  conversationId String
  direction      WhatsAppMessageDirection
  messageType    WhatsAppMessageType      @default(TEXT)
  textContent    String?
  mediaMetaId    String?
  mediaMimeType  String?
  mediaFilename  String?
  mediaCaption   String?
  mediaSizeBytes Int?
  sentByBot      Boolean                  @default(false)
  sentByUserId   String?
  metaMessageId  String                   @unique
  status         WhatsAppMessageStatus
  errorCode      String?
  errorMessage   String?
  createdAt      DateTime                 @default(now())
  deliveredAt    DateTime?
  readAt         DateTime?

  conversation WhatsAppConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy       User?                @relation(fields: [sentByUserId], references: [id])

  @@index([conversationId, createdAt])
  @@index([status])
  @@map("whatsapp_messages")
}

model WhatsAppUnregisteredContact {
  id                   String                            @id @default(uuid())
  condominiumId        String
  phoneNumber          String
  capturedUnitNumber   String?
  capturedName         String?
  conversationCount    Int                               @default(1)
  messageCount         Int                               @default(0)
  lastSeenAt           DateTime
  status               WhatsAppUnregisteredContactStatus @default(NEW)
  registeredResidentId String?
  notes                String?
  identityPromptSentAt DateTime?
  createdAt            DateTime                          @default(now())
  updatedAt            DateTime                          @updatedAt

  condominium   Condominium            @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  conversations WhatsAppConversation[]

  @@unique([condominiumId, phoneNumber])
  @@index([condominiumId, status, lastSeenAt])
  @@map("whatsapp_unregistered_contacts")
}

model WhatsAppNotificationPreference {
  id                      String                @id @default(uuid())
  userId                  String
  condominiumId           String
  notifyOnEscalation      Boolean               @default(true)
  notifyChannel           WhatsAppNotifyChannel @default(WHATSAPP)
  personalPhoneNumber     String?
  personalPhoneVerifiedAt DateTime?
  // DEPRECATED (notifications iter2): single-device Web Push subscription.
  // Superseded by the multi-device `PushSubscription` table; backfilled by
  // migration `20260601140000_add_push_subscriptions` and no longer written.
  // Kept one release for rollback safety; a follow-up migration drops it.
  pushSubscriptionJson    Json?
  reNotifyAfterMinutes    Int?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, condominiumId])
  @@index([condominiumId, personalPhoneNumber])
  @@map("whatsapp_notification_preferences")
}

/// One Web Push subscription per browser/device (notifications iter2 — multi-device).
/// Replaces the single `WhatsAppNotificationPreference.pushSubscriptionJson` field so a
/// user can receive push on phone + desktop simultaneously. `endpoint` is globally unique
/// (it identifies the browser push channel); dispatch fans out to every row for a
/// `(userId, condominiumId)` pair, and a gone (404/410) subscription deletes its own row.
model PushSubscription {
  id            String   @id @default(uuid())
  userId        String
  condominiumId String
  endpoint      String   @unique
  p256dh        String
  auth          String
  createdAt     DateTime @default(now())
  lastSeenAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  @@index([userId, condominiumId])
  @@map("push_subscriptions")
}

model R2AccessLog {
  id            String       @id @default(uuid())
  objectKey     String       @db.VarChar(1024)
  bucket        String?
  condominiumId String?
  userId        String?
  accessType    R2AccessType
  byteSize      Int?
  accessedAt    DateTime     @default(now())

  condominium Condominium? @relation(fields: [condominiumId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([objectKey, accessedAt])
  @@index([condominiumId, accessedAt])
  @@index([userId, accessedAt])
  @@index([accessType])
  @@map("r2_access_logs")
}

// Visitor entry/exit log kept at the gate by security staff (RBAC Phase 4 —
// Seguridad module). A row is created on check-in; checkOutAt is set when the
// visitor leaves (null = still inside). residentId optionally links the visit to
// a resident in the directory; unit is free text so condos that don't model
// units can still record where the visitor went.
model VisitorLog {
  id            String    @id @default(uuid())
  condominiumId String
  residentId    String?
  visitorName   String
  unit          String
  plate         String?
  checkInAt     DateTime  @default(now())
  checkOutAt    DateTime?
  notes         String?
  // API-owned audit fields — the acting security user, never the request body.
  createdBy     String?
  updatedBy     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  resident    Resident?   @relation(fields: [residentId], references: [id])

  @@index([condominiumId])
  @@index([condominiumId, checkOutAt])
  @@index([residentId])
  @@index([deletedAt])
  @@map("visitor_logs")
}

// ─── Support Center ─────────────────────────────────────────────────────────
// The knowledge-base CONTENT lives in the web repo (i18n + a typed content
// registry); the API only persists engagement metrics + support tickets.

enum SupportRequestType {
  TECHNICAL
  USAGE
  IMPROVEMENT
  DATA_ISSUE
  ADMIN
}

enum SupportPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SupportModule {
  DASHBOARD
  IMPORTS
  RECONCILIATION
  RESIDENTS
  REPORTS
  INVENTORY
  SETTINGS
  AUTH
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum HelpVoteValue {
  HELPFUL
  NOT_HELPFUL
}

// Global (NOT tenant-scoped) per-article aggregate: one row per article slug.
// helpfulCount / notHelpfulCount are denormalized totals kept in sync with
// HelpArticleVote inside a transaction on every vote mutation. Rows are created
// lazily on first view/feedback — there is no canonical slug list in the API.
model HelpArticleMetric {
  slug            String   @id @db.VarChar(160)
  viewCount       Int      @default(0)
  helpfulCount    Int      @default(0)
  notHelpfulCount Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  votes HelpArticleVote[]

  @@index([viewCount]) // ORDER BY viewCount DESC for "popular articles"
  @@map("help_article_metrics")
}

// One vote per user per article — lets a user change or retract their vote and
// blocks ballot stuffing. Deleting the vote (retract) is allowed.
model HelpArticleVote {
  id        String        @id @default(uuid())
  slug      String        @db.VarChar(160)
  userId    String
  value     HelpVoteValue
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  article HelpArticleMetric @relation(fields: [slug], references: [slug], onDelete: Cascade)
  user    User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([slug, userId])
  @@index([userId])
  @@map("help_article_votes")
}

// Support ticket from the "¿No encontraste lo que buscabas?" form. Tenant-scoped
// and tied to the creating user — both are API-owned (from the session), never
// from the request body. screenshotKey is the R2 object key (presigned on read).
model SupportTicket {
  id            String              @id @default(uuid())
  condominiumId String
  userId        String
  requestType   SupportRequestType
  priority      SupportPriority
  module        SupportModule
  description   String              @db.VarChar(2000)
  status        SupportTicketStatus @default(OPEN)
  screenshotKey String?             @db.VarChar(1024)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  condominium Condominium @relation(fields: [condominiumId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@index([condominiumId, createdAt])
  @@index([userId, createdAt])
  @@index([status])
  @@map("support_tickets")
}

// ─── Resident dossier (antecedentes) — Capa 2 ───────────────────────────────
// Case-management record of non-financial resident antecedents (sanctions,
// legal cases, coexistence conflicts, property/vehicle issues, dangerous pets).
// Sensitive legal/reputational data: per-record confidentiality (filtered by
// permission), HIGH severity requires documentary backing, and reads/writes are
// audited via AuditLog. See web `resident-dossier` namespace + module.

enum DossierCategory {
  SANCTION
  LEGAL
  COEXISTENCE
  PROPERTY
  DANGEROUS_PET
}

enum DossierSeverity {
  LOW
  MEDIUM
  HIGH
}

enum DossierStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ARCHIVED
}

enum DossierConfidentiality {
  STANDARD
  RESTRICTED
  LEGAL_CONFIDENTIAL
}

enum DossierEventType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  UPDATED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
}

model ResidentDossierEntry {
  id              String                 @id @default(uuid())
  condominiumId   String
  residentId      String
  category        DossierCategory
  severity        DossierSeverity        @default(LOW)
  status          DossierStatus          @default(OPEN)
  confidentiality DossierConfidentiality @default(STANDARD)
  title           String
  description     String
  // Documentary backing: acta #, expediente legal, folio de guardia. Required by
  // the service when severity is HIGH (evidence rule). File attachments arrive
  // in phase 2B.
  referenceFolio  String?
  // Fine/sanction amount or cost-to-condominium of a lawsuit.
  amount          Decimal?               @db.Decimal(12, 2)
  occurredAt      DateTime               @db.Date
  resolvedAt      DateTime?              @db.Date
  // Category-specific structured extras (e.g. legal: lawsuitCount, courtCase).
  metadata        Json?
  // API-owned actor fields — JWT sub of the acting user, never request input.
  createdBy       String?
  updatedBy       String?
  deletedAt       DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  condominium Condominium         @relation(fields: [condominiumId], references: [id])
  resident    Resident            @relation(fields: [residentId], references: [id], onDelete: Cascade)
  events      DossierEvent[]
  attachments DossierAttachment[]

  @@index([condominiumId])
  @@index([residentId])
  @@index([residentId, category])
  @@index([confidentiality])
  @@index([deletedAt])
  @@map("resident_dossier_entries")
}

// Evidence files for a dossier entry (acta/sentencia PDF, guard report, photos),
// stored in R2. Only metadata lives here; the bytes are in R2 under `storageKey`,
// which is NEVER exposed to the client — views go through a presigned GET issued
// on demand. Phase 2B.
model DossierAttachment {
  id             String   @id @default(uuid())
  condominiumId  String
  dossierEntryId String
  fileName       String   @db.VarChar(512)
  storageKey     String   @db.VarChar(1024)
  mimeType       String   @db.VarChar(128)
  fileSizeBytes  Int
  uploadedBy     String?
  uploadedAt     DateTime @default(now())

  dossierEntry ResidentDossierEntry @relation(fields: [dossierEntryId], references: [id], onDelete: Cascade)

  @@index([dossierEntryId])
  @@index([condominiumId])
  @@map("dossier_attachments")
}

// Append-only history of a dossier entry (creation, status change, notes). Feeds
// the case timeline, independent of the global AuditLog.
model DossierEvent {
  id             String           @id @default(uuid())
  condominiumId  String
  dossierEntryId String
  type           DossierEventType
  fromStatus     DossierStatus?
  toStatus       DossierStatus?
  note           String?
  createdBy      String?
  createdAt      DateTime         @default(now())

  dossierEntry ResidentDossierEntry @relation(fields: [dossierEntryId], references: [id], onDelete: Cascade)

  @@index([dossierEntryId])
  @@index([condominiumId])
  @@map("dossier_events")
}

// ─── ARCO data-subject requests (Capa 2F) ───────────────────────────────────
// Case-management tracker for LFPDPPP ARCO rights — Acceso / Rectificación /
// Cancelación / Oposición. An admin LOGS a request a resident submitted and
// tracks it to resolution; the actual data change is performed elsewhere and
// recorded here (v1 = tracker). An ACCESS request can trigger the existing
// dossier ARCO packet (Capa 2D/2E).
enum ArcoRequestType {
  ACCESS
  RECTIFICATION
  CANCELLATION
  OPPOSITION
}

enum ArcoRequestStatus {
  // Identity not yet verified — the request is logged but substantive handling
  // (and the 20-business-day clock) starts once the data subject is verified.
  PENDING_VERIFICATION
  RECEIVED
  IN_REVIEW
  COMPLETED
  REJECTED
}

enum ArcoRequestEventType {
  CREATED
  STATUS_CHANGED
  NOTE_ADDED
  UPDATED
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  ACCESS_PACKET_GENERATED
  // Phase 7a — SLA automation, notifications & retention.
  OVERDUE
  ESCALATED_BY_SYSTEM
  NOTIFIED
  RETENTION_PURGE
}

// Legal basis for processing the ARCO request (LFPDPPP / GDPR Art. 6 analog).
enum ArcoLegalBasis {
  CONSENT
  CONTRACT
  LEGAL_OBLIGATION
  VITAL_INTEREST
  PUBLIC_TASK
  LEGITIMATE_INTEREST
}

// How the requester's identity was confirmed before substantive handling.
enum ArcoIdentityVerificationMethod {
  GOVERNMENT_ID
  PASSPORT
  CURP
  AGENT_NOTARIZED
  OTHER
}

// Type of official ID the requester presented (the number is stored masked).
enum ArcoRequesterIdType {
  INE
  PASSPORT
  CURP
  OTHER
}

// Relationship of the requester to the data subject.
enum ArcoRequesterRelationship {
  SELF
  LEGAL_AGENT
  AUTHORIZED_REPRESENTATIVE
}

model ArcoRequest {
  id             String            @id @default(uuid())
  condominiumId  String
  residentId     String
  type           ArcoRequestType
  status         ArcoRequestStatus @default(RECEIVED)
  // How the request arrived (in person, email, …) — free text.
  channel        String?
  // What the data subject asked for.
  description    String
  // Admin's resolution notes once handled.
  resolution     String?
  // Mandatory written justification when status = REJECTED (LFPDPPP Art. 12).
  rejectionReason String?
  // Official reference (oficio/acta) backing the request or its resolution.
  referenceFolio String?

  // --- Compliance: legal basis & identity verification (LFPDPPP Art. 12) ---
  legalBasis                 ArcoLegalBasis?
  // Identity of the person who filed the request and their standing.
  requesterName              String?
  requesterRelationship      ArcoRequesterRelationship?
  requesterIdType            ArcoRequesterIdType?
  // Only the last digits are kept; the service masks before persisting.
  requesterIdNumberMasked    String?
  // Whether the requester's identity has been confirmed. While false the
  // request sits in PENDING_VERIFICATION.
  identityVerified           Boolean                         @default(false)
  identityVerificationMethod ArcoIdentityVerificationMethod?
  identityVerifiedAt         DateTime?
  // API-owned actor field — JWT sub of the verifying user.
  identityVerifiedBy         String?
  // When the resident submitted it (admin-set; defaults to now).
  receivedAt     DateTime          @default(now())
  // LFPDPPP legal response deadline — denormalized at creation
  // (receivedAt + ARCO_RESPONSE_BUSINESS_DAYS business days).
  dueDate        DateTime
  resolvedAt     DateTime?
  // API-owned actor fields — JWT sub of the acting user, never request input.
  createdBy      String?
  updatedBy      String?
  deletedAt      DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  condominium Condominium             @relation(fields: [condominiumId], references: [id])
  resident    Resident                @relation(fields: [residentId], references: [id], onDelete: Cascade)
  events      ArcoRequestEvent[]
  attachments ArcoRequestAttachment[]

  @@index([condominiumId])
  @@index([residentId])
  @@index([residentId, status])
  @@index([dueDate])
  @@index([deletedAt])
  @@map("arco_requests")
}

// Evidence files for an ARCO request (the written request, ID, resolution oficio),
// stored in R2. Only metadata here; bytes live in R2 under `storageKey`, never
// exposed to the client — views go through a presigned GET on demand.
model ArcoRequestAttachment {
  id            String   @id @default(uuid())
  condominiumId String
  arcoRequestId String
  fileName      String   @db.VarChar(512)
  storageKey    String   @db.VarChar(1024)
  mimeType      String   @db.VarChar(128)
  fileSizeBytes Int
  uploadedBy    String?
  uploadedAt    DateTime @default(now())

  arcoRequest ArcoRequest @relation(fields: [arcoRequestId], references: [id], onDelete: Cascade)

  @@index([arcoRequestId])
  @@index([condominiumId])
  @@map("arco_request_attachments")
}

// Append-only history of an ARCO request (creation, status change, notes,
// access-packet generation). Feeds the case timeline, independent of AuditLog.
model ArcoRequestEvent {
  id            String               @id @default(uuid())
  condominiumId String
  arcoRequestId String
  type          ArcoRequestEventType
  fromStatus    ArcoRequestStatus?
  toStatus      ArcoRequestStatus?
  note          String?
  createdBy     String?
  createdAt     DateTime             @default(now())

  arcoRequest ArcoRequest @relation(fields: [arcoRequestId], references: [id], onDelete: Cascade)

  @@index([arcoRequestId])
  @@index([condominiumId])
  @@map("arco_request_events")
}
