model Supplier {
  id                       String             @id @default(uuid())
  condominiumId            String
  supplierName             String
  type                     SupplierType
  // Coarse directory bucket driving the Proveedores filter chips. Backfilled
  // from `type` for legacy rows; defaults to OTHER for new ones that omit it.
  category                 SupplierCategory   @default(OTHER)
  // FIXED → recurring "Proveedor fijo"; OCCASIONAL → ad-hoc "Eventual".
  engagementType           SupplierEngagement @default(OCCASIONAL)
  contactName              String?
  email                    String?
  phone                    String?
  whatsapp                 String?
  address                  String?
  // Free-text schedule / availability shown in the contact panel.
  availability             String?
  // Whether the supplier also serves residents privately (trust reference).
  servesResidents          Boolean            @default(false)
  // Trust/reference notes (who recommends them, prior experience). Kept
  // separate from `notes` (internal/admin remarks).
  references               String?
  taxId                    String?
  // When set, classifying an EXPENSE to this supplier auto-fills this category
  // (in the review modal and via EXPENSE reconciliation rules). Optional.
  defaultExpenseCategoryId String?
  registrationDate         DateTime?          @db.Date
  status                   SupplierStatus     @default(ACTIVE)
  notes                    String?
  deletedAt                DateTime?
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  // Audit-trail actor ids (the JWT `sub` of the acting user). API-owned: set
  // from the session on create/update, never accepted from the request body.
  // Nullable so rows created before this column existed remain valid.
  createdBy                String?
  updatedBy                String?

  condominium            Condominium          @relation(fields: [condominiumId], references: [id])
  defaultExpenseCategory ExpenseCategory?     @relation(fields: [defaultExpenseCategoryId], references: [id])
  transactions           Transaction[]
  reconciliationRules    ReconciliationRule[]
  ratings                SupplierRating[]

  @@index([condominiumId])
  @@index([condominiumId, status])
  @@index([condominiumId, type])
  @@index([condominiumId, category])
  @@index([condominiumId, engagementType])
  @@index([condominiumId, defaultExpenseCategoryId])
  @@index([deletedAt])
  @@map("suppliers")
}

