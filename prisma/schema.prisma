// ─── Models ───────────────────────────────────────────────────────────────────

model Condominium {
  id           String   @id @default(uuid())
  slug         String   @unique
  name         String
  legalName    String?
  primaryColor String   @default("#6366f1")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings                         CondominiumSettings?
  users                            User[]
  roles                            Role[]
  residents                        Resident[]
  vehicles                         Vehicle[]
  pets                             Pet[]
  pettyCashMovements               PettyCashMovement[]
  commonAreas                      CommonArea[]
  inventoryItems                   InventoryItem[]
  suppliers                        Supplier[]
  supplierRatings                  SupplierRating[]
  expenseCategories                ExpenseCategory[]
  importBatches                    ImportBatch[]
  transactions                     Transaction[]
  collectionRecords                CollectionRecord[]
  auditLogs                        AuditLog[]
  notifications                    Notification[]
  financialMonthlySummaries        FinancialMonthlySummary[]
  reconciliationRules              ReconciliationRule[]
  reconciliationRuleChangeLogs     ReconciliationRuleChangeLog[]
  paymentAllocations               PaymentAllocation[]
  reconciliationCorrectionPatterns ReconciliationCorrectionPattern[]
  calendarEvents                   CalendarEvent[]
  whatsAppCredential               WhatsAppCredential?
  whatsAppBotConfig                WhatsAppBotConfig?
  whatsAppFaqs                     WhatsAppFaq[]
  whatsAppConversations            WhatsAppConversation[]
  whatsAppUnregisteredContacts     WhatsAppUnregisteredContact[]
  whatsAppNotificationPrefs        WhatsAppNotificationPreference[]
  bankProfiles                     BankProfile[]
  r2AccessLogs                     R2AccessLog[]
  visitorLogs                      VisitorLog[]
  pushSubscriptions                PushSubscription[]
  supportTickets                   SupportTicket[]
  residentDossierEntries           ResidentDossierEntry[]
  arcoRequests                     ArcoRequest[]
  quotationRequests                QuotationRequest[]
  quotations                       Quotation[]

  @@map("condominiums")
}

model CondominiumSettings {
  id            String   @id @default(uuid())
  condominiumId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // General
  logoUrl           String?
  logoUpdatedAt     DateTime?
  logoUpdatedByName String?
  timezone          String    @default("America/Monterrey")
  country           String    @default("MX")
  currency          String    @default("MXN")
  address           String?
  adminPhone        String?
  contactEmail      String?
  businessHours     Json      @default("{}")
  defaultLocale     String    @default("es")

  // Resident dossier (antecedentes) retention — Capa 2D. Days after soft-delete
  // before the recycle bin is auto-purged. 0 = no window (opt-in per condominium);
  // LEGAL category / LEGAL_CONFIDENTIAL entries are never auto-purged regardless.
  dossierRetentionDays Int @default(0)
  // Whether the scheduled auto-purge actually runs. The sweep only purges when
  // this is true AND dossierRetentionDays > 0, so an admin can pause the purge
  // without losing the configured window. Shared gate for the ARCO retention
  // sweep below.
  autopurgeEnabled Boolean @default(false)

  // ARCO (data-subject rights) retention — months after a request is resolved
  // (COMPLETED/REJECTED) before it and its evidence are auto-purged. 0 = no
  // window (opt-in per condominium). Gated by autopurgeEnabled. Mexican law
  // commonly keeps these ~6 years (72 months) for liability evidence.
  arcoRetentionMonths Int @default(0)

  // Financial-health score weights — Fase 4. Per-condominium override of the 7
  // factor weights (onTime, collectionRate, monthsCurrent, delinquencyAge,
  // balance, recurrence, trend). Null = documented defaults. Auto-normalized to
  // sum 100 at compute time, so the stored values are relative importances.
  financialHealthWeights Json?

  // Fees
  totalUnits              Int     @default(1)
  ordinaryFeeAmount       Decimal @default(0) @db.Decimal(12, 2)
  extraordinaryFeeAmount  Decimal @default(0) @db.Decimal(12, 2)
  paymentFrequency        String  @default("monthly")
  ordinaryPaymentDayStart Int     @default(1)
  ordinaryPaymentDayEnd   Int     @default(10)
  lateFeeAmount           Decimal @default(0) @db.Decimal(12, 2)
  lateFeeStartDay         Int     @default(11)

  // Financial / Import
  maxFilesPerImport Int     @default(5)
  allowedFilePdf    Boolean @default(true)
  allowedFileExcel  Boolean @default(true)

  // Terrace Booking
  terraceBookingEnabled        Boolean  @default(true)
  terraceRentalAmount          Decimal  @default(1500) @db.Decimal(12, 2)
  terraceSecurityDepositAmount Decimal  @default(1000) @db.Decimal(12, 2)
  terraceDefaultStartTime      String   @default("10:00")
  terraceDefaultEndTime        String   @default("11:00")
  terraceGlobalKeywords        String[] @default([])

  condominium Condominium @relation(fields: [condominiumId], references: [id], onDelete: Cascade)

  @@map("condominium_settings")
}

enum OnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

// Per-user visual mode. SYSTEM mirrors the OS prefers-color-scheme; LIGHT/DARK
// are explicit overrides. Drives the web's next-themes setting across devices.
enum UiThemeMode {
  LIGHT
  DARK
  SYSTEM
}

// Per-user locale override. NULL on the preference row means "inherit the
// condominium default" (CondominiumSettings.defaultLocale); a value here wins.
enum UiLocale {
  es
  en
}

model User {
  id                    String    @id @default(uuid())
  condominiumId         String?
  email                 String
  passwordHash          String
  // Dynamic RBAC (RBAC Phase 2). The assigned Role row is the single source of
  // truth for role + permissions; the legacy `role` enum column was removed. The
  // role key (Role.key) and effective permissions are read via roleRef.
  roleId                String?
  firstName             String
  lastName              String
  phone                 String?
  avatarUrl             String?
  sessionDuration       Int       @default(8)
  // Minutes of inactivity before the in-app screen lock engages. Per-user so an
  // office shared workstation (admin) can be tighter than a low-risk profile.
  // Enforced server-side via RefreshToken.lastActivityAt — see InactivityLockGuard.
  inactivityLockMinutes Int       @default(15)
  isActive              Boolean   @default(true)
  // Per-user permission overrides (RBAC Phase 3). NULL = inherit the assigned
  // role's permissions; a JSON array of catalog keys = the explicit effective
  // set for this user (independent of the role). Resolved by
  // resolveEffectivePermissions: overrides ?? roleRef.permissions.
  permissionOverrides   Json?
  lastLoginAt           DateTime?
  deletedAt             DateTime?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Dashboard onboarding tour — per-user progress so it survives cookie/storage
  // clears and follows the user across devices. onboardingStep stores the last
  // step reached while IN_PROGRESS so the tour can resume where it was left.
  onboardingStatus      OnboardingStatus @default(NOT_STARTED)
  onboardingStep        Int              @default(0)
  onboardingCompletedAt DateTime?
  onboardingSkippedAt   DateTime?

  condominium               Condominium?                     @relation(fields: [condominiumId], references: [id])
  roleRef                   Role?                            @relation(fields: [roleId], references: [id])
  refreshTokens             RefreshToken[]
  passwordResetTokens       PasswordResetToken[]
  pettyCashRegistered       PettyCashMovement[]              @relation("RegisteredBy")
  pettyCashUpdated          PettyCashMovement[]              @relation("UpdatedBy")
  importBatches             ImportBatch[]                    @relation("ImportedBy")
  importFilesDeleted        ImportBatch[]                    @relation("ImportFileDeletedBy")
  auditLogs                 AuditLog[]
  notifications             Notification[]
  reconciledTransactions    Transaction[]                    @relation("ReconciledBy")
  createdCalendarEvents     CalendarEvent[]                  @relation("CreatedCalendarEvents")
  updatedCalendarEvents     CalendarEvent[]                  @relation("UpdatedCalendarEvents")
  whatsAppFaqsCreated       WhatsAppFaq[]                    @relation("FaqCreatedBy")
  whatsAppFaqsUpdated       WhatsAppFaq[]                    @relation("FaqUpdatedBy")
  whatsAppMessagesSent      WhatsAppMessage[]
  whatsAppConvsTakenOver    WhatsAppConversation[]           @relation("ConversationTakenOverBy")
  whatsAppConvsResolved     WhatsAppConversation[]           @relation("ConversationResolvedBy")
  whatsAppNotificationPrefs WhatsAppNotificationPreference[]
  notificationPreferences   UserNotificationPreference[]
  rootNotificationScope     RootNotificationScope?
  notificationSoundPref     UserNotificationSoundPreference?
  uiPreference              UserUiPreference?
  r2AccessLogs              R2AccessLog[]
  pushSubscriptions         PushSubscription[]
  helpArticleVotes          HelpArticleVote[]
  supportTickets            SupportTicket[]

  @@unique([condominiumId, email])
  @@index([condominiumId])
  @@index([email])
  @@index([roleId])
  @@index([deletedAt])
  @@map("users")
}

// Dynamic RBAC (RBAC Phase 1). Roles are DATA (rows) so new roles can be created
// from the UI without code changes; permissions are a CODE-defined catalog
// (src/common/rbac/permission-catalog.ts) because each key maps to a real guard
// check. `permissions` holds catalog keys; it is validated against the catalog on
// write. System roles (isSystem=true) are seeded and keyed (ROOT, SUPERVISOR,
// TENANT_ADMIN, READ_ONLY, GUARD, NEIGHBOR); custom roles have key=null and are
// scoped to a condominium. Effective permissions are read live from this table
// (cached), so changes apply without forcing a re-login.
model Role {
  id            String    @id @default(uuid())
  key           String?   @unique
  name          String
  description   String?
  isSystem      Boolean   @default(false)
  isActive      Boolean   @default(true)
  condominiumId String?
  permissions   String[]  @default([])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  condominium Condominium? @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([condominiumId, name])
  @@index([condominiumId])
  @@index([key])
  @@map("roles")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  // In-app inactivity screen lock (server-authoritative). A session is locked
  // when lockedAt is set, or when now - lastActivityAt exceeds the user's
  // inactivityLockMinutes. Only the heartbeat / unlock endpoints refresh
  // lastActivityAt, so background polling never keeps a session alive.
  // failedUnlockAttempts forces a logout after repeated wrong passwords.
  lastActivityAt       DateTime?
  lockedAt             DateTime?
  failedUnlockAttempts Int       @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model Resident {
  id                   String        @id @default(uuid())
  condominiumId        String
  unitNumber           String
  // Canonical (trimmed, lower-cased) unit number. Uniqueness is enforced on
  // this so "A1" and "a1" are the same unit within a condominium; `unitNumber`
  // keeps the original casing for display. Always set by the service.
  unitNumberNormalized String
  residentType         ResidentType  @default(OWNER)
  firstName            String
  lastName             String
  phone                String?
  secondaryPhone       String?
  email                String?
  paymentStatus        PaymentStatus @default(CURRENT)
  debt                 Decimal       @default(0) @db.Decimal(12, 2)
  monthlyFee           Decimal       @default(0) @db.Decimal(12, 2)
  parkingSpots         Int           @default(0)
  houseModel           String?
  documentation        Json          @default("{\"propertyTax\":false,\"titleDeed\":false,\"ownerDocumentation\":false,\"nationalId\":false,\"proofOfAddress\":false}")
  notes                String?
  deletedAt            DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  condominium                      Condominium                       @relation(fields: [condominiumId], references: [id])
  vehicles                         Vehicle[]
  pets                             Pet[]
  additionalResidents              AdditionalResident[]
  transactions                     Transaction[]
  collectionRecords                CollectionRecord[]
  paymentAllocations               PaymentAllocation[]
  reconciliationCorrectionPatterns ReconciliationCorrectionPattern[]
  calendarEvents                   CalendarEvent[]
  whatsAppConversations            WhatsAppConversation[]
  visitorLogs                      VisitorLog[]
  dossierEntries                   ResidentDossierEntry[]
  arcoRequests                     ArcoRequest[]

  @@unique([condominiumId, unitNumberNormalized])
  @@index([condominiumId])
  @@index([paymentStatus])
  @@index([deletedAt])
  @@map("residents")
}

model AdditionalResident {
  id             String       @id @default(uuid())
  residentId     String
  name           String
  residentType   ResidentType @default(RESIDENT)
  phone          String?
  secondaryPhone String?
  email          String?
  relationship   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  resident Resident @relation(fields: [residentId], references: [id], onDelete: Cascade)

  @@index([residentId])
  @@map("additional_residents")
}

model Vehicle {
  id            String   @id @default(uuid())
  residentId    String
  condominiumId String
  make          String
  model         String
  color         String?
  plates        String
  hasTag        Boolean  @default(false)
  tagId         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resident    Resident    @relation(fields: [residentId], references: [id], onDelete: Cascade)
  condominium Condominium @relation(fields: [condominiumId], references: [id])

  @@index([residentId])
  @@index([condominiumId])
  @@index([plates])
  @@map("vehicles")
}

model Pet {
  id            String   @id @default(uuid())
  residentId    String
  condominiumId String
  name          String
  petType       PetType  @default(OTHER)
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  resident    Resident    @relation(fields: [residentId], references: [id], onDelete: Cascade)
  condominium Condominium @relation(fields: [condominiumId], references: [id])

  @@index([residentId])
  @@index([condominiumId])
  @@map("pets")
}

model PettyCashMovement {
  id             String           @id @default(uuid())
  condominiumId  String
  folio          String
  date           DateTime         @db.Date
  movementType   MovementType
  category       MovementCategory
  concept        String
  amount         Decimal          @db.Decimal(12, 2)
  runningBalance Decimal          @db.Decimal(12, 2)
  status         MovementStatus   @default(PENDING)
  deliveryMethod DeliveryMethod   @default(CASH)
  responsible    String
  supplier       String?
  hasReceipt     Boolean          @default(false)
  receiptNumber  String?
  authorizedBy   String?
  notes          String?
  registeredById String
  updatedById    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  condominium  Condominium @relation(fields: [condominiumId], references: [id])
  registeredBy User        @relation("RegisteredBy", fields: [registeredById], references: [id])
  updatedBy    User?       @relation("UpdatedBy", fields: [updatedById], references: [id])

  @@unique([condominiumId, folio])
  @@index([condominiumId])
  @@index([status])
  @@index([date])
  @@map("petty_cash_movements")
}

model CommonArea {
  id                String           @id @default(uuid())
  condominiumId     String
  name              String
  // DEPRECATED (CMA-010, Phase 5): common areas use the free-text `name` as the
  // single source of truth. `nameKey` is no longer written or read by the API
  // or the web client. The column is intentionally kept (nullable) to avoid a
  // data-loss migration; it can be dropped in a future, dedicated migration
  // once confirmed unused across all environments.
  nameKey           String?
  description       String?
  physicalLocation  String?
  status            CommonAreaStatus @default(ACTIVE)
  responsiblePerson String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  // Audit-trail actor ids (the JWT `sub` of the acting user). API-owned: set
  // from the session on create/update, never accepted from the request body.
  // Nullable so rows created before this column existed remain valid.
  createdBy         String?
  updatedBy         String?

  condominium    Condominium     @relation(fields: [condominiumId], references: [id])
  inventoryItems InventoryItem[]

  @@index([condominiumId])
  @@index([status])
  @@map("common_areas")
}

