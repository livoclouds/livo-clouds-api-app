  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  condominium Condominium      @relation(fields: [condominiumId], references: [id])
  request     QuotationRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@index([requestId])
  @@index([condominiumId])
  @@map("quotations")
}

/// Condo-editable catalog that classifies EXPENSE transactions (e.g.
/// "Administración", "Vigilancia", "Jardinería"). The income side keeps using the
/// hardcoded `paymentConcept` enum; this is the expense-side counterpart, modeled
/// as data so each condominium can tailor its own categories.
model ExpenseCategory {
  id            String    @id @default(uuid())
  condominiumId String
  // Human-facing label. Source of truth for custom categories; for seeded
  // "system" categories the web app prefers the i18n key derived from systemKey
  // and falls back to this.
  name          String
  // Stable key for built-in/default categories (e.g. "ADMINISTRATION"). Lets the
  // web app localize the label via t() and lets default EXPENSE rules anchor to a
  // category without hardcoding a generated id. Null for custom rows.
  systemKey     String?
  // Optional badge/chart color token (hsl or hex).
  color         String?
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  // True for seeded defaults; guards the rows the engine ships with from deletion.
  isSystem      Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  // Audit-trail actor ids (the acting user's JWT `sub`). API-owned.
  createdBy     String?
  updatedBy     String?

  condominium         Condominium          @relation(fields: [condominiumId], references: [id], onDelete: Cascade)
  transactions        Transaction[]
  reconciliationRules ReconciliationRule[]
  defaultForSuppliers Supplier[]

  @@index([condominiumId])
  @@index([condominiumId, isActive])
  @@index([condominiumId, systemKey])
  @@index([deletedAt])
  @@map("expense_categories")
}

