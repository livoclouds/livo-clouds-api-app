// Client generator (DB-011). `output` is intentionally left at the Prisma
// default (`node_modules/.prisma/client`): pinning it would change the
// `@prisma/client` import path and force a repo-wide import refactor for no
// functional gain at the current scale. No preview features are in use.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

